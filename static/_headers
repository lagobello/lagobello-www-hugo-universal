# Cloudflare Pages reads this at deploy time. Hugo copies /static/_headers
# verbatim into /public/_headers.
#
# IMPORTANT: Cloudflare Pages applies ALL matching rules and concatenates
# duplicate header values. So the /* catch-all must NOT set Cache-Control,
# otherwise the catch-all's max-age stacks on top of every specific rule and
# the shortest max-age wins per RFC 7234. Specific rules also can't overlap
# each other; e.g. /img/lots/* ⊂ /img/* would double-stack on lot photos.
# Each Cache-Control rule below covers a non-overlapping path set.

# Hugo image-pipeline output (content-hashed via `_hu_<hash>`).
/img/lots/*
  Cache-Control: public, max-age=31536000, immutable

# Other image subdirectories — enumerated to avoid /img/* overlapping with
# /img/lots/* and double-stacking Cache-Control on lot photos.
/img/photographs/*
  Cache-Control: public, max-age=2592000
/img/blog/*
  Cache-Control: public, max-age=2592000
/img/clients/*
  Cache-Control: public, max-age=2592000
/img/realtors/*
  Cache-Control: public, max-age=2592000
/img/tools/*
  Cache-Control: public, max-age=2592000

# Root-level /img assets are not covered by Cloudflare Pages' path rules
# above. Keep these explicit so they don't overlap image subdirectories.
/img/apple-touch-icon.png
  Cache-Control: public, max-age=2592000
/img/favicon.ico
  Cache-Control: public, max-age=2592000
/img/lago-logo-500-500.png
  Cache-Control: public, max-age=2592000
/img/placeholder-home.png
  Cache-Control: public, max-age=2592000

# Static assets without content hashes — long-ish TTL; redeploy + Cloudflare
# purge to flip sooner if needed.
/css/*
  Cache-Control: public, max-age=2592000
/js/*
  Cache-Control: public, max-age=2592000
/webfonts/*
  Cache-Control: public, max-age=31536000, immutable

# Frequently-updated data.
/files/*
  Cache-Control: public, max-age=86400
/data/*
  Cache-Control: public, max-age=86400

# Catch-all: security headers ONLY (no Cache-Control to avoid stacking).
# HTML and any path not covered above falls through to Cloudflare Pages'
# default Cache-Control, which is short-lived and appropriate for HTML.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
